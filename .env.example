# API key de Gemini para fallback de deteccion via IA (opcional).
# Si la dejas vacia, la API funciona solo con heuristicas.
# Genera una gratis en https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Modelo de Gemini a usar como primera opcion. Si da 429, hay cascada interna
# a gemini-2.5-flash-lite y gemini-1.5-flash-8b.
GEMINI_MODEL=gemini-2.0-flash

# Proxy residencial opcional. Util si corres el scraper desde una VM cloud
# y algun dominio te bloquea por IP.
# Formato: http://user:pass@host:port
PROXY_URL=
